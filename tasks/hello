apiVersion: tekton.dev/v1
kind: Task
metadata:
  name: hello-task
spec:
  params:
    - name: message
      type: string
      default: "hello"
  steps:
    - name: echo
      image: alpine:3.20
      script: |
        #!/bin/sh
        echo "$(params.message)"
